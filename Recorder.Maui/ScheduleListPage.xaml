<?xml version="1.0" encoding="UTF-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui" xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml" x:Class="Recorder.ScheduleListPage">
    <CollectionView x:Name="scheduleListView"
              Margin="10"
              SelectionMode="Single"
              SelectionChanged="OnItemSelected"
              AutomationId="ScheduleListView">
        <CollectionView.ItemTemplate>
            <DataTemplate>
                <ContentView Padding="5"
                             AutomationId="{Binding TestId}">
                    <StackLayout Orientation="Vertical">
                        <Label Text="{Binding Title}" />
                        <Label Text="{Binding Description}" />
                    </StackLayout>
                </ContentView>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
</ContentPage>
